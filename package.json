{
  "name": "@xiaobailong/web-update-notice-plugin",
  "version": "1.0.5",
  "description": "A plugin that notifies users to refresh the page when a new version is deployed. Supports Vite, Nuxt and Webpack.",
  "files": [
    "dist"
  ],
  "main": "./dist/vite.cjs",
  "module": "./dist/vite.mjs",
  "types": "./dist/vite.d.cts",
  "exports": {
    ".": {
      "types": {
        "require": "./dist/vite.d.cts",
        "import": "./dist/vite.d.mts"
      },
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.mjs"
    },
    "./vite": {
      "types": {
        "require": "./dist/vite.d.cts",
        "import": "./dist/vite.d.mts"
      },
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.mjs"
    },
    "./nuxt": {
      "types": {
        "require": "./dist/nuxt.d.cts",
        "import": "./dist/nuxt.d.mts"
      },
      "require": "./dist/nuxt.cjs",
      "import": "./dist/nuxt.mjs"
    },
    "./webpack": {
      "types": {
        "require": "./dist/webpack.d.cts",
        "import": "./dist/webpack.d.mts"
      },
      "require": "./dist/webpack.cjs",
      "import": "./dist/webpack.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepublishOnly": "pnpm build",
    "release": "pnpm publish --access public",
    "release:patch": "npm version patch && pnpm publish --access public",
    "release:minor": "npm version minor && pnpm publish --access public",
    "release:major": "npm version major && pnpm publish --access public"
  },
  "keywords": [
    "vite",
    "plugin",
    "vite-plugin",
    "update",
    "notice"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaobailong007/web-update-notice-plugin.git"
  },
  "homepage": "https://github.com/xiaobailong007/web-update-notice-plugin#readme",
  "bugs": {
    "url": "https://github.com/xiaobailong007/web-update-notice-plugin/issues"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "html-webpack-plugin": "^5.6.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vite-plus": "^0.1.13",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "vite": ">=2.0.0"
  }
}
