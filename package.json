{
  "name": "@xiaobailong/web-update-notice-plugin",
  "version": "2.0.4",
  "description": "🔔 一款网页更新通知插件，在系统发布新版本时自动提醒用户刷新页面 🔄。全面支持 Vite、Nuxt 和 Webpack 生态 ⚡。",
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "default": "./dist/vite.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "default": "./dist/vite.mjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.mts",
      "import": "./dist/nuxt.mjs",
      "default": "./dist/nuxt.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs",
      "default": "./dist/webpack.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "test:e2e": "vp test --mode e2e",
    "check:exports": "publint",
    "check": "pnpm run check:exports",
    "prepublishOnly": "pnpm run build && pnpm run check",
    "release": "changeset publish",
    "version": "changeset version",
    "clean": "rimraf dist node_modules pnpm-lock.yaml",
    "up": "pnpm run clean && pnpm update --latest",
    "changeset": "pnpm exec changeset"
  },
  "keywords": [
    "vite",
    "plugin",
    "vite-plugin",
    "update",
    "notice"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaobailong007/web-update-notice-plugin.git"
  },
  "homepage": "https://github.com/xiaobailong007/web-update-notice-plugin#readme",
  "bugs": {
    "url": "https://github.com/xiaobailong007/web-update-notice-plugin/issues"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "html-webpack-plugin": "^5.6.6",
    "publint": "^0.3.18",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.14",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "vite": ">=2.0.0",
    "nuxt": ">=3.0.0",
    "webpack": ">=5.0.0",
    "html-webpack-plugin": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "html-webpack-plugin": {
      "optional": true
    }
  }
}
