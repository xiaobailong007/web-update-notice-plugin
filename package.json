{
  "name": "@xiaobailong/web-update-notice-plugin",
  "version": "1.0.12",
  "description": "A plugin that notifies users to refresh the page when a new version is deployed. Supports Vite, Nuxt and Webpack.",
  "files": [
    "dist"
  ],
  "main": "./dist/vite.cjs",
  "module": "./dist/vite.mjs",
  "types": "./dist/vite.d.cts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "typesVersions": {
    "*": {
      "vite": [
        "./dist/vite.d.cts",
        "./dist/vite.d.mts"
      ],
      "nuxt": [
        "./dist/nuxt.d.cts",
        "./dist/nuxt.d.mts"
      ],
      "webpack": [
        "./dist/webpack.d.cts",
        "./dist/webpack.d.mts"
      ]
    }
  },
  "size-limit": [
    {
      "path": "dist/vite.mjs",
      "limit": "10 kB",
      "ignore": [
        "node:*",
        "path",
        "fs",
        "util",
        "vm",
        "crypto",
        "events",
        "url",
        "module",
        "tty",
        "os",
        "assert",
        "stream",
        "zlib",
        "process",
        "http",
        "https",
        "perf_hooks",
        "querystring",
        "constants",
        "worker_threads",
        "child_process",
        "string_decoder",
        "buffer",
        "net",
        "tls"
      ]
    },
    {
      "path": "dist/nuxt.mjs",
      "limit": "100 kB",
      "ignore": [
        "node:*",
        "path",
        "fs",
        "util",
        "vm",
        "crypto",
        "events",
        "url",
        "module",
        "tty",
        "os",
        "assert",
        "stream",
        "zlib",
        "process",
        "http",
        "https",
        "perf_hooks",
        "querystring",
        "constants",
        "worker_threads",
        "child_process",
        "string_decoder",
        "buffer",
        "net",
        "tls"
      ]
    },
    {
      "path": "dist/webpack.mjs",
      "limit": "1 MB",
      "ignore": [
        "node:*",
        "path",
        "fs",
        "util",
        "vm",
        "crypto",
        "events",
        "url",
        "module",
        "tty",
        "os",
        "assert",
        "stream",
        "zlib",
        "process",
        "http",
        "https",
        "perf_hooks",
        "querystring",
        "constants",
        "worker_threads",
        "child_process",
        "string_decoder",
        "buffer",
        "net",
        "tls"
      ]
    }
  ],
  "exports": {
    ".": {
      "types": {
        "require": "./dist/vite.d.cts",
        "import": "./dist/vite.d.mts"
      },
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.mjs"
    },
    "./vite": {
      "types": {
        "require": "./dist/vite.d.cts",
        "import": "./dist/vite.d.mts"
      },
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.mjs"
    },
    "./nuxt": {
      "types": {
        "require": "./dist/nuxt.d.cts",
        "import": "./dist/nuxt.d.mts"
      },
      "require": "./dist/nuxt.cjs",
      "import": "./dist/nuxt.mjs"
    },
    "./webpack": {
      "types": {
        "require": "./dist/webpack.d.cts",
        "import": "./dist/webpack.d.mts"
      },
      "require": "./dist/webpack.cjs",
      "import": "./dist/webpack.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "test:e2e": "vp test --mode e2e",
    "check:exports": "publint",
    "check:types": "attw --pack",
    "check:size": "size-limit",
    "check": "pnpm run check:exports && pnpm run check:types && pnpm run check:size",
    "prepublishOnly": "pnpm run build && pnpm run check",
    "release": "changeset publish",
    "version": "changeset version"
  },
  "keywords": [
    "vite",
    "plugin",
    "vite-plugin",
    "update",
    "notice"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaobailong007/web-update-notice-plugin.git"
  },
  "homepage": "https://github.com/xiaobailong007/web-update-notice-plugin#readme",
  "bugs": {
    "url": "https://github.com/xiaobailong007/web-update-notice-plugin/issues"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "@size-limit/preset-small-lib": "^12.0.1",
    "html-webpack-plugin": "^5.6.6",
    "publint": "^0.3.18",
    "size-limit": "^12.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vite-plus": "^0.1.13",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "vite": ">=2.0.0"
  }
}
